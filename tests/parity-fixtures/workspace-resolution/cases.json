{
  "_doc": "Shared behavioral-parity fixtures for the Model B workspace resolver (f-ws-resolution, s-ws-res-parity). BOTH packages/sdk-py/tests/test_workspace_resolution.py and packages/sdk-ts/tests/workspace-resolution.test.ts read this file and assert resolve_workspace() matches `expect`. Identical cases -> identical outcomes -> Py<->TS parity is enforced: if either implementation diverges, its suite fails. `expect.workspace` = the resolved workspace_id; `expect.deny` = a substring that MUST appear in the raised CrossWorkspaceError; `expect.workspace: null` = a passthrough None (stdio). `identity` claims are the VERIFIED token; `memberships` are WorkspaceMembership specs.",
  "cases": [
    {
      "id": "stdio-passthrough-none",
      "why": "No token (stdio/OSS) -> requested passes through unchanged, even to None.",
      "token_present": false,
      "identity": null,
      "requested": null,
      "memberships": [],
      "expect": { "workspace": null }
    },
    {
      "id": "stdio-passthrough-requested",
      "why": "No token -> a requested value passes through verbatim (base path untouched).",
      "token_present": false,
      "identity": null,
      "requested": "anything",
      "memberships": [],
      "expect": { "workspace": "anything" }
    },
    {
      "id": "sole-membership-oid-bound",
      "why": "Golden: a bound identity with one active membership resolves to it, no selector.",
      "token_present": true,
      "identity": { "oid": "oid-alice", "email": "alice@a.com", "tid": "org-a" },
      "requested": null,
      "memberships": [
        { "workspace_id": "ws-a", "identity_email": "alice@a.com", "identity_oid": "oid-alice", "role": "owner", "status": "active" }
      ],
      "expect": { "workspace": "ws-a" }
    },
    {
      "id": "seed-unbound-active-email-match",
      "why": "The F1 founder seed: active grant with identity_oid=null matches the VERIFIED email until oid binds.",
      "token_present": true,
      "identity": { "oid": "oid-founder", "email": "Jefferson.Barnabe@gmail.com", "tid": "c5b891f7" },
      "requested": null,
      "memberships": [
        { "workspace_id": "c5b891f7", "identity_email": "jefferson.barnabe@gmail.com", "identity_oid": null, "role": "owner", "status": "active" }
      ],
      "expect": { "workspace": "c5b891f7" }
    },
    {
      "id": "email-case-folded",
      "why": "Email matching is case-insensitive on both sides.",
      "token_present": true,
      "identity": { "oid": "oid-bob", "email": "BOB@B.COM", "tid": "org-b" },
      "requested": null,
      "memberships": [
        { "workspace_id": "ws-b", "identity_email": "bob@b.com", "identity_oid": null, "role": "member", "status": "active" }
      ],
      "expect": { "workspace": "ws-b" }
    },
    {
      "id": "deny-no-membership",
      "why": "Authenticated identity with zero active memberships -> fail-closed deny.",
      "token_present": true,
      "identity": { "oid": "oid-nobody", "email": "nobody@x.com", "tid": "org-x" },
      "requested": null,
      "memberships": [
        { "workspace_id": "ws-a", "identity_email": "alice@a.com", "identity_oid": "oid-alice", "role": "owner", "status": "active" }
      ],
      "expect": { "deny": "no active workspace membership" }
    },
    {
      "id": "deny-pending-only",
      "why": "A pending (unaccepted) invite authorizes nothing — must be active.",
      "token_present": true,
      "identity": { "oid": "oid-invitee", "email": "invitee@x.com", "tid": "org-x" },
      "requested": null,
      "memberships": [
        { "workspace_id": "ws-a", "identity_email": "invitee@x.com", "identity_oid": null, "role": "member", "status": "pending" }
      ],
      "expect": { "deny": "no active workspace membership" }
    },
    {
      "id": "deny-cross-workspace-requested",
      "why": "ISOLATION: a member of ws-a that requests ws-b (no membership there) is denied.",
      "token_present": true,
      "identity": { "oid": "oid-alice", "email": "alice@a.com", "tid": "org-a" },
      "requested": "ws-b",
      "memberships": [
        { "workspace_id": "ws-a", "identity_email": "alice@a.com", "identity_oid": "oid-alice", "role": "owner", "status": "active" },
        { "workspace_id": "ws-b", "identity_email": "bob@b.com", "identity_oid": "oid-bob", "role": "owner", "status": "active" }
      ],
      "expect": { "deny": "not an active member of workspace 'ws-b'" }
    },
    {
      "id": "requested-own-workspace-allowed",
      "why": "A member naming its OWN workspace as the selector is allowed (re-verified).",
      "token_present": true,
      "identity": { "oid": "oid-alice", "email": "alice@a.com", "tid": "org-a" },
      "requested": "ws-a",
      "memberships": [
        { "workspace_id": "ws-a", "identity_email": "alice@a.com", "identity_oid": "oid-alice", "role": "owner", "status": "active" }
      ],
      "expect": { "workspace": "ws-a" }
    },
    {
      "id": "multi-membership-selector-picks-one",
      "why": "Cross-org collaboration: an identity in TWO workspaces selects one explicitly.",
      "token_present": true,
      "identity": { "oid": "oid-barna", "email": "barna@labs.com", "tid": "org-a" },
      "requested": "ws-partner",
      "memberships": [
        { "workspace_id": "ws-labs", "identity_email": "barna@labs.com", "identity_oid": "oid-barna", "role": "owner", "status": "active" },
        { "workspace_id": "ws-partner", "identity_email": "barna@labs.com", "identity_oid": "oid-barna", "role": "member", "status": "active" }
      ],
      "expect": { "workspace": "ws-partner" }
    },
    {
      "id": "multi-membership-no-selector-ambiguous-deny",
      "why": "Multiple memberships and no selector -> fail-closed (must name one).",
      "token_present": true,
      "identity": { "oid": "oid-barna", "email": "barna@labs.com", "tid": "org-a" },
      "requested": null,
      "memberships": [
        { "workspace_id": "ws-labs", "identity_email": "barna@labs.com", "identity_oid": "oid-barna", "role": "owner", "status": "active" },
        { "workspace_id": "ws-partner", "identity_email": "barna@labs.com", "identity_oid": "oid-barna", "role": "member", "status": "active" }
      ],
      "expect": { "deny": "belongs to multiple workspaces" }
    },
    {
      "id": "bound-oid-mismatch-ignores-email",
      "why": "SECURITY: a bound grant matches ONLY on oid — a different oid with the same email is denied (no email-hijack of a bound membership).",
      "token_present": true,
      "identity": { "oid": "oid-attacker", "email": "alice@a.com", "tid": "org-evil" },
      "requested": null,
      "memberships": [
        { "workspace_id": "ws-a", "identity_email": "alice@a.com", "identity_oid": "oid-alice", "role": "owner", "status": "active" }
      ],
      "expect": { "deny": "no active workspace membership" }
    }
  ]
}

{
  "_doc": "Behavioral golden fixtures for the Model B workspace-OWNERSHIP pure policy (f-ws-owner-provision, s-ws-provision-owner-endpoint + s-ws-revoke-endpoint). packages/sdk-py/tests/test_workspace_ownership.py runs every case against the pure policy. Two case families discriminated by `op`: 'owners' exercises active_owners + has_active_owner (the provision-owner idempotency/first-owner probe); 'revoke' exercises plan_revoke (RBAC + the last-owner protection). This is SECURITY-critical: the last-owner-cannot-be-revoked invariant and the non-owner-cannot-revoke RBAC deny live here and are gated here.",
  "owners": [
    {
      "id": "owners-single-active",
      "why": "One active owner → that owner is the sole owner; has_active_owner true.",
      "workspace_id": "ws-a",
      "memberships": [
        {
          "workspace_id": "ws-a",
          "identity_email": "owner@a.com",
          "identity_oid": "oid-owner",
          "role": "owner",
          "status": "active"
        },
        {
          "workspace_id": "ws-a",
          "identity_email": "mem@a.com",
          "identity_oid": "oid-mem",
          "role": "member",
          "status": "active"
        }
      ],
      "expect": {
        "owners": [
          "owner@a.com"
        ],
        "has_active_owner": true
      }
    },
    {
      "id": "owners-none-when-no-owner-grant",
      "why": "A workspace with only members/admins has no owner → has_active_owner false (the provision gap being fixed).",
      "workspace_id": "ws-a",
      "memberships": [
        {
          "workspace_id": "ws-a",
          "identity_email": "adm@a.com",
          "identity_oid": "oid-adm",
          "role": "admin",
          "status": "active"
        }
      ],
      "expect": {
        "owners": [],
        "has_active_owner": false
      }
    },
    {
      "id": "owners-pending-owner-does-not-count",
      "why": "A pending owner invite authorizes nothing → not an active owner (fail-closed).",
      "workspace_id": "ws-a",
      "memberships": [
        {
          "workspace_id": "ws-a",
          "identity_email": "owner@a.com",
          "identity_oid": null,
          "role": "owner",
          "status": "pending"
        }
      ],
      "expect": {
        "owners": [],
        "has_active_owner": false
      }
    },
    {
      "id": "owners-unbound-active-seed-counts",
      "why": "The F1 founder seed (active owner, oid still null) IS an active owner — it counts.",
      "workspace_id": "ws-a",
      "memberships": [
        {
          "workspace_id": "ws-a",
          "identity_email": "founder@a.com",
          "identity_oid": null,
          "role": "owner",
          "status": "active"
        }
      ],
      "expect": {
        "owners": [
          "founder@a.com"
        ],
        "has_active_owner": true
      }
    },
    {
      "id": "owners-two-active-owners",
      "why": "Two active owners → both listed (first-seen order); has_active_owner true.",
      "workspace_id": "ws-a",
      "memberships": [
        {
          "workspace_id": "ws-a",
          "identity_email": "a@a.com",
          "identity_oid": "oid-a",
          "role": "owner",
          "status": "active"
        },
        {
          "workspace_id": "ws-a",
          "identity_email": "b@a.com",
          "identity_oid": "oid-b",
          "role": "owner",
          "status": "active"
        }
      ],
      "expect": {
        "owners": [
          "a@a.com",
          "b@a.com"
        ],
        "has_active_owner": true
      }
    },
    {
      "id": "owners-scoped-to-workspace",
      "why": "An owner of ws-b is not an owner of ws-a (per-workspace boundary).",
      "workspace_id": "ws-a",
      "memberships": [
        {
          "workspace_id": "ws-b",
          "identity_email": "owner@b.com",
          "identity_oid": "oid-b",
          "role": "owner",
          "status": "active"
        }
      ],
      "expect": {
        "owners": [],
        "has_active_owner": false
      }
    }
  ],
  "revoke": [
    {
      "id": "revoke-owner-removes-member",
      "why": "Golden: an owner revokes a member — allowed.",
      "workspace_id": "ws-a",
      "actor_role": "owner",
      "target": {
        "workspace_id": "ws-a",
        "identity_email": "mem@a.com",
        "identity_oid": "oid-mem",
        "role": "member",
        "status": "active"
      },
      "memberships": [
        {
          "workspace_id": "ws-a",
          "identity_email": "owner@a.com",
          "identity_oid": "oid-owner",
          "role": "owner",
          "status": "active"
        },
        {
          "workspace_id": "ws-a",
          "identity_email": "mem@a.com",
          "identity_oid": "oid-mem",
          "role": "member",
          "status": "active"
        }
      ],
      "expect": {
        "allowed": true,
        "reason": "ok"
      }
    },
    {
      "id": "revoke-admin-removes-pending-invite",
      "why": "An admin may revoke a pending invite (RBAC owner/admin; pending is revocable).",
      "workspace_id": "ws-a",
      "actor_role": "admin",
      "target": {
        "workspace_id": "ws-a",
        "identity_email": "inv@a.com",
        "identity_oid": null,
        "role": "member",
        "status": "pending"
      },
      "memberships": [
        {
          "workspace_id": "ws-a",
          "identity_email": "owner@a.com",
          "identity_oid": "oid-owner",
          "role": "owner",
          "status": "active"
        },
        {
          "workspace_id": "ws-a",
          "identity_email": "adm@a.com",
          "identity_oid": "oid-adm",
          "role": "admin",
          "status": "active"
        },
        {
          "workspace_id": "ws-a",
          "identity_email": "inv@a.com",
          "identity_oid": null,
          "role": "member",
          "status": "pending"
        }
      ],
      "expect": {
        "allowed": true,
        "reason": "ok"
      }
    },
    {
      "id": "revoke-non-owner-denied",
      "why": "SECURITY: a member (no owner/admin role) cannot revoke anyone — RBAC deny (403).",
      "workspace_id": "ws-a",
      "actor_role": "member",
      "target": {
        "workspace_id": "ws-a",
        "identity_email": "other@a.com",
        "identity_oid": "oid-other",
        "role": "member",
        "status": "active"
      },
      "memberships": [
        {
          "workspace_id": "ws-a",
          "identity_email": "owner@a.com",
          "identity_oid": "oid-owner",
          "role": "owner",
          "status": "active"
        },
        {
          "workspace_id": "ws-a",
          "identity_email": "other@a.com",
          "identity_oid": "oid-other",
          "role": "member",
          "status": "active"
        }
      ],
      "expect": {
        "allowed": false,
        "reason": "not_authorized"
      }
    },
    {
      "id": "revoke-no-role-denied",
      "why": "SECURITY: an actor with no membership at all cannot revoke — RBAC deny (403).",
      "workspace_id": "ws-a",
      "actor_role": null,
      "target": {
        "workspace_id": "ws-a",
        "identity_email": "mem@a.com",
        "identity_oid": "oid-mem",
        "role": "member",
        "status": "active"
      },
      "memberships": [
        {
          "workspace_id": "ws-a",
          "identity_email": "owner@a.com",
          "identity_oid": "oid-owner",
          "role": "owner",
          "status": "active"
        },
        {
          "workspace_id": "ws-a",
          "identity_email": "mem@a.com",
          "identity_oid": "oid-mem",
          "role": "member",
          "status": "active"
        }
      ],
      "expect": {
        "allowed": false,
        "reason": "not_authorized"
      }
    },
    {
      "id": "revoke-last-owner-denied",
      "why": "SECURITY: the sole remaining active owner cannot be revoked — the workspace must never be orphaned (fail-closed).",
      "workspace_id": "ws-a",
      "actor_role": "owner",
      "target": {
        "workspace_id": "ws-a",
        "identity_email": "owner@a.com",
        "identity_oid": "oid-owner",
        "role": "owner",
        "status": "active"
      },
      "memberships": [
        {
          "workspace_id": "ws-a",
          "identity_email": "owner@a.com",
          "identity_oid": "oid-owner",
          "role": "owner",
          "status": "active"
        },
        {
          "workspace_id": "ws-a",
          "identity_email": "mem@a.com",
          "identity_oid": "oid-mem",
          "role": "member",
          "status": "active"
        }
      ],
      "expect": {
        "allowed": false,
        "reason": "last_owner"
      }
    },
    {
      "id": "revoke-one-of-two-owners-allowed",
      "why": "With two active owners, revoking one is allowed (the other still holds the workspace).",
      "workspace_id": "ws-a",
      "actor_role": "owner",
      "target": {
        "workspace_id": "ws-a",
        "identity_email": "a@a.com",
        "identity_oid": "oid-a",
        "role": "owner",
        "status": "active"
      },
      "memberships": [
        {
          "workspace_id": "ws-a",
          "identity_email": "a@a.com",
          "identity_oid": "oid-a",
          "role": "owner",
          "status": "active"
        },
        {
          "workspace_id": "ws-a",
          "identity_email": "b@a.com",
          "identity_oid": "oid-b",
          "role": "owner",
          "status": "active"
        }
      ],
      "expect": {
        "allowed": true,
        "reason": "ok"
      }
    },
    {
      "id": "revoke-target-not-found",
      "why": "Revoking an identity that holds no grant here is a clear no-op/not_found (idempotent-ish).",
      "workspace_id": "ws-a",
      "actor_role": "owner",
      "target": null,
      "memberships": [
        {
          "workspace_id": "ws-a",
          "identity_email": "owner@a.com",
          "identity_oid": "oid-owner",
          "role": "owner",
          "status": "active"
        }
      ],
      "expect": {
        "allowed": false,
        "reason": "not_found"
      }
    },
    {
      "id": "revoke-last-owner-checked-before-rbac-is-still-denied",
      "why": "Even a legitimate owner cannot revoke the last owner (themselves) — last_owner protection holds regardless of RBAC pass.",
      "workspace_id": "ws-a",
      "actor_role": "owner",
      "target": {
        "workspace_id": "ws-a",
        "identity_email": "solo@a.com",
        "identity_oid": "oid-solo",
        "role": "owner",
        "status": "active"
      },
      "memberships": [
        {
          "workspace_id": "ws-a",
          "identity_email": "solo@a.com",
          "identity_oid": "oid-solo",
          "role": "owner",
          "status": "active"
        }
      ],
      "expect": {
        "allowed": false,
        "reason": "last_owner"
      }
    }
  ]
}

"hosted" for agentos ≈ self-host (this app + compose.yaml) + an optional
control-plane REGISTRATION step (design §2/§6). INSTRUCTIONS is the DNA-composed
prompt, carried byte-equal. Run it with `python main.py` (serves on {{port}}).
"""
from agno.agent import Agent
from agno.os import AgentOS

INSTRUCTIONS = {{{instructions_literal}}}


def build_agent() -> Agent:
    """Build the AgentOS-served agent (single-service JWT identity)."""
    return Agent(
        name={{{name_literal}}},
{{#has_model}}        model={{{model_literal}}},
{{/has_model}}        instructions=INSTRUCTIONS,
    )


agent = build_agent()
agent_os = AgentOS(agents=[agent])
app = agent_os.get_app()


if __name__ == "__main__":
    # AgentOS serves the REST / AG-UI surface on {{port}}.
    agent_os.serve(app="main:app", port={{port}})

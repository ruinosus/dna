"""DNA-emitted Agno copilot agent: {{name}}.

Generated by `dna emit --target agno` (copilot case). INSTRUCTIONS is the
DNA-composed prompt (Soul + guardrails + instruction), carried byte-equal — edit
the agent in DNA and re-emit, never hand-edit the prompt here.

`build_agent` is the per-run factory (cheap + network-free — mirrors the
Agno KB reference agent factory): the serving layer calls it with the run's
session_state so tenant/knowledge stay fresh without a restart.
"""
from __future__ import annotations

{{#needs_os}}import os

{{/needs_os}}from agno.agent import Agent
{{#pg_db}}from agno.db.postgres import PostgresDb
{{/pg_db}}{{^pg_db}}from agno.db.in_memory import InMemoryDb
{{/pg_db}}{{#has_pgvector}}from agno.knowledge.embedder.openai import OpenAIEmbedder
from agno.knowledge.knowledge import Knowledge
{{/has_pgvector}}{{#has_model}}from agno.models.openai import OpenAILike
{{/has_model}}{{#has_pgvector}}from agno.vectordb.pgvector import PgVector, SearchType
{{/has_pgvector}}{{#has_mcp}}from agno.tools.mcp import MCPTools
{{/has_mcp}}
INSTRUCTIONS = {{{instructions_literal}}}

{{#has_mcp}}

def _mcp_tools() -> list[MCPTools]:
    """The DNA MCP server(s) this copilot mounts over Streamable HTTP. The
    toolkit is CONSTRUCTED but NOT connected here — connecting is async and
    happens inside the AG-UI run loop. Tool bodies live on the remote MCP
    server, not in this scaffold.

    HITL (Spike 0A: gate-remote-directly): the DNA write tools are gated DIRECTLY
    on the remote MCP tool via `external_execution_required_tools` — no local
    wrapper. Agno pauses the run when the model calls a gated tool
    (`RunStatus.paused`, the tool in `tools_awaiting_external_execution`); the
    AG-UI approval card answers and Agno's router resumes it (`acontinue_run`)."""
    return [
{{#mcp_servers}}        MCPTools(
            url={{{url_literal}}},
            transport={{{transport_literal}}},
{{#has_external_tools}}            external_execution_required_tools={{{external_tools_literal}}},
{{/has_external_tools}}        ),
{{/mcp_servers}}    ]
{{/has_mcp}}{{#has_knowledge}}{{#has_pgvector}}

def _knowledge() -> Knowledge:
    """The RAG store this copilot reads (`Copilot.knowledge`: {{knowledge_refs}}).
    DNA declares a pgvector store (`knowledge.store`), so this binds a REAL Agno
    `Knowledge(vector_db=PgVector(...))` over Postgres — the DSN comes from the
    `{{vector_ref}}` infra ref via its env var (f-copilot-infra-binding wires it),
    NEVER a hardcoded literal. The corpus CONTENT is loaded per-app (call
    `_knowledge().add_content(...)` at wire-up)."""
    return Knowledge(
        vector_db=PgVector(
            table_name={{{vector_table_literal}}},
            db_url={{{vector_db_url_expr}}},
            search_type=SearchType.hybrid,
            embedder=OpenAIEmbedder(id={{{embed_model_literal}}}, dimensions={{embed_dims}}),
        ),
    )
{{/has_pgvector}}{{^has_pgvector}}

def _knowledge() -> object | None:
    """The RAG collection(s) this copilot may read
    (`Copilot.knowledge.collections`: {{knowledge_refs}}). DNA carries the
    collection REFS; the retrieval implementation — the vector store + embedder
    (e.g. Agno `Knowledge(vector_db=PgVector(...), contents_db=...)`, mirroring
    the Agno KB reference's `build_knowledge`) — is PER-APP (design §6.3). This
    is the WIRING POINT: build your `Knowledge` over the collections above and
    return it. Returning None (the scaffold default) leaves the agent corpus-free
    (`search_knowledge=False`), exactly like a pure-action copilot."""
    # TODO(consumer): bind + return an Agno Knowledge over: {{knowledge_refs}}
    return None
{{/has_pgvector}}{{/has_knowledge}}

def build_agent(session_state: dict | None = None) -> Agent:
    """Build the Agno Agent for one run. No network is touched at build time — the
    model is constructed lazily.{{#pg_db}} `db` binds Agno's `PostgresDb` to the `{{checkpoint_ref}}`
    infra ref (DSN read from its env var — f-copilot-infra-binding wires it), so
    thread/run state{{#enable_user_memories}} + cross-session user memories{{/enable_user_memories}} survive restarts and HITL resume
    works across processes.{{/pg_db}}{{^pg_db}} `db` is an in-memory default so HITL resume (paused
    runs) works out of the box; swap it for a persistent Agno db at wire-up.{{/pg_db}}"""
{{#has_knowledge}}    knowledge = _knowledge()
{{/has_knowledge}}    return Agent(
        name={{{name_literal}}},
{{#has_model}}        model=OpenAILike(id={{{model_literal}}}),
{{/has_model}}        instructions=INSTRUCTIONS,
{{#has_mcp}}        tools=_mcp_tools(),
{{/has_mcp}}{{#has_knowledge}}        knowledge=knowledge,
        search_knowledge=knowledge is not None,
{{/has_knowledge}}        db={{#pg_db}}PostgresDb(db_url={{{pg_db_url_expr}}}){{/pg_db}}{{^pg_db}}InMemoryDb(){{/pg_db}},
{{#enable_user_memories}}        enable_user_memories=True,
{{/enable_user_memories}}        session_state=session_state or {},
        add_session_state_to_context=True,
        markdown=True,
    )

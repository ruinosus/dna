# DNA-emitted thin AgentOS compose scaffold: {{name}} (target=agentos).
# Agno AgentOS has no managed runtime — this is a SINGLE-service self-host
# scaffold. Wire the managed Postgres/Redis + JWT secrets + ingress via
# f-copilot-infra-binding (the Terraform closure), NOT this file.
services:
  {{module}}:
    build: .
    ports:
      - "{{port}}:{{port}}"
    environment:
      - AGENTOS_JWT_SECRET
    restart: unless-stopped

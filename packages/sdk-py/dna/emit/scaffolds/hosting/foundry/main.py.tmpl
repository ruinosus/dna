"""DNA-emitted Foundry hosted agent: {{name}} (hosting.mode=hosted, target=foundry).

Generated by `dna emit` (hosting case). Packages the mounted agent as a Foundry
*hosted agent*: a container that serves the Responses protocol on {{port}} via
`agent_framework_foundry_hosting.ResponsesHostServer`, invoked through the Foundry
gateway. INSTRUCTIONS is the DNA-composed prompt (Soul + guardrails + instruction),
carried byte-equal ‚Äî edit the agent in DNA and re-emit, never hand-edit it here.

DEGRADED single-identity variant (design ¬ß2). This is the HOSTED sibling of the
self-hosted AG-UI app: `hosting.mode` is a variant selector over ONE agent def.
The hosted variant DROPS the per-user concerns that don't fit the hosted
single-identity, request/response model:
  - per-user OBO ‚Äî auth is the platform-injected AGENT identity
    (`DefaultAzureCredential`), not the signed-in user;
  - HITL approval ‚Äî the MCP mount carries NO `approval_mode` (no approval card),
    write tools run under the agent identity;
  - per-user long-term memory ‚Äî Foundry hosting manages conversation history.
Emit the self-hosted variant (`hosting.mode: self-hosted`) for the per-user
AG-UI app that keeps OBO / HITL / per-user memory. Config comes from env, injected
by the platform (f-copilot-infra-binding wires the infra refs ‚Üí env vars).
"""
{{#needs_os}}import os

{{/needs_os}}from agent_framework import Agent
from agent_framework.foundry import FoundryChatClient
from agent_framework_foundry_hosting import ResponsesHostServer
from azure.identity import DefaultAzureCredential
{{#has_mcp}}from agent_framework import MCPStreamableHTTPTool
{{/has_mcp}}{{#has_pgvector}}from agent_framework.postgres import PostgresVectorStore
{{/has_pgvector}}
INSTRUCTIONS = {{{instructions_literal}}}
{{#has_mcp}}

def _mcp_tools() -> list[MCPStreamableHTTPTool]:
    """The DNA MCP server(s) this hosted agent mounts over Streamable HTTP. The
    DEGRADE: no `approval_mode` (HITL stripped) and no `header_provider` (per-user
    OBO/tenant stripped) ‚Äî a single service identity. `allowed_tools` still bounds
    what the model may call; tool bodies live on the remote MCP server."""
    return [
{{#mcp_servers}}        MCPStreamableHTTPTool(
            name={{{name_literal}}},
            url={{{url_literal}}},
            allowed_tools={{{allowed_tools_literal}}},
        ),
{{/mcp_servers}}    ]
{{/has_mcp}}{{#has_pgvector}}


def _vector_store() -> PostgresVectorStore:
    """The single-identity RAG grounding that SURVIVES the degrade (`Copilot.
    knowledge`): shared-corpus retrieval, not per-user memory. Binds MS-AF's
    `PostgresVectorStore` ‚Äî the DSN comes from the `{{vector_ref}}` infra ref via its
    env var (f-copilot-infra-binding wires it), NEVER a hardcoded literal. Load the
    corpus CONTENT per-app."""
    return PostgresVectorStore(
        collection_name={{{vector_collection_literal}}},
        connection_string={{{vector_db_url_expr}}},
        embedding_model={{{embed_model_literal}}},
        embedding_dimensions={{embed_dims}},
    )
{{/has_pgvector}}


def build_agent() -> Agent:
    """Build the hosted MS Agent Framework agent ‚Äî a Foundry-backed ChatAgent under
    the platform-injected agent identity (`FoundryChatClient(...).as_agent(...)`)."""
    client = FoundryChatClient(
{{#has_model}}        model={{{model_literal}}},
{{/has_model}}        credential=DefaultAzureCredential(),
    )
    return client.as_agent(
        name={{{name_literal}}},
        instructions=INSTRUCTIONS,
{{#has_mcp}}        tools=_mcp_tools(),
{{/has_mcp}}{{#has_pgvector}}        context_providers=[_vector_store()],
{{/has_pgvector}}    )


def main() -> None:
    """Serve the agent over the Responses protocol on {{port}}. `ResponsesHostServer`
    is the bridge ‚Äî it serves any agent over /responses for the Foundry gateway."""
    ResponsesHostServer(build_agent()).run()


if __name__ == "__main__":
    main()

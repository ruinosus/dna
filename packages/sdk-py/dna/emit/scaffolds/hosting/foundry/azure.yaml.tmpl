# yaml-language-server: $schema=https://raw.githubusercontent.com/Azure/azure-dev/main/schemas/v1.0/azure.yaml.json
#
# DNA-emitted Foundry hosted-agent service block for {{name}} (target=foundry).
# `host: azure.ai.agent` is the NON-deprecated Foundry hosted-agent manifest (NOT
# the deprecated `agent.yaml`). Merge this `services:` entry into your azd
# `azure.yaml` and set `project:` to this service's directory. `azd deploy` builds
# the image{{#remote_build}} (remoteBuild via ACR){{/remote_build}} and publishes a new agent
# VERSION — the agent version is a deploy step, NOT an ARM resource (design §3).
services:
  {{service_name}}:
    project: .
    host: azure.ai.agent
    language: docker
    docker:
{{#remote_build}}      remoteBuild: true
{{/remote_build}}{{^remote_build}}      path: Dockerfile
{{/remote_build}}    config:
{{#has_resources}}      container:
        resources:
          cpu: {{{cpu_literal}}}
          memory: {{{memory_literal}}}
{{/has_resources}}      startupCommand: python main.py

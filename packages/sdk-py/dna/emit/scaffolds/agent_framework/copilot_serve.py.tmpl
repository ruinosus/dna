"""DNA-emitted Microsoft Agent Framework copilot serving app: {{name}}.

Generated by `dna emit --target agent-framework` (copilot case). Serves the
mounted {{mounted_kind}} over the AG-UI protocol at `/agui` via
`add_agent_framework_fastapi_endpoint`. Run it with any ASGI server, e.g.
`uvicorn {{agent_module}}_serve:app`.
"""
from fastapi import FastAPI{{#tenant_propagate}}, Request{{/tenant_propagate}}

from agent_framework_ag_ui import add_agent_framework_fastapi_endpoint
{{#has_workflow}}from agent_framework_ag_ui import AgentFrameworkWorkflow
{{/has_workflow}}from {{agent_module}} import {{build_fn}}
{{#tenant_propagate}}from {{agent_module}} import (
    reset_request_tenant,
    set_request_tenant,
    tenant_from_headers,
)
{{/tenant_propagate}}
app = FastAPI()
{{#tenant_propagate}}


@app.middleware("http")
async def _derive_tenant(request: Request, call_next):
    """Derive the per-run DNA tenant/oid from inbound request headers into the
    request-scoped ContextVar the MCP header_provider reads (the inbound->outbound
    tenant bridge — NOT a propagate_tenant freebie)."""
    token = set_request_tenant(tenant_from_headers(request.headers))
    try:
        return await call_next(request)
    finally:
        reset_request_tenant(token)
{{/tenant_propagate}}


#: The mounted {{mounted_kind}}, served at `/agui` (the AG-UI protocol). `uvicorn
#: {{agent_module}}_serve:app` runs it.
add_agent_framework_fastapi_endpoint(
    app,
    agent={{serve_agent_expr}},
    path="/agui",
)

// DNA-emitted resume-adapter — MS Agent Framework target ({{{agent_id}}}).
//
// The CopilotKit runtime validates `resume` as an ARRAY (the AG-UI client form,
// [{ interruptId, status, payload }]), but the agent-framework backend expects a
// DICT ({ interrupts: [{ id, value }] }). This adapter overrides the HttpAgent's
// fetch to translate the body just before it reaches the backend, so a paused
// workflow interrupt can resume. (The Agno target needs no such bridge — it
// resumes natively — which is why the resume-adapter is the one per-runtime file.)
import { HttpAgent } from "@ag-ui/client";

interface ResumeEntry {
  interruptId?: string;
  id?: string;
  payload?: unknown;
  value?: unknown;
}

export function buildAgent(url: string, headers?: Record<string, string>): HttpAgent {
  return new HttpAgent({
    url,
    headers,
    fetch: async (input, init) => {
      if (init?.body && typeof init.body === "string") {
        try {
          const body = JSON.parse(init.body) as { resume?: unknown };
          if (Array.isArray(body.resume)) {
            body.resume = {
              interrupts: (body.resume as ResumeEntry[]).map((r) => ({
                id: r.interruptId ?? r.id,
                value: r.payload ?? r.value,
              })),
            };
            init = { ...init, body: JSON.stringify(body) };
          }
        } catch {
          // leave the body untouched when it isn't JSON
        }
      }
      return fetch(input, init);
    },
  });
}

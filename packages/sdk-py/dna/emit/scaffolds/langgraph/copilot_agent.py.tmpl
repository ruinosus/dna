{{#has_hitl}}

def _review_node(state: State) -> dict:
    """Workflow-level graph-enforced HITL: a dedicated `interrupt()` node appended to
    the chain (the LangGraph-native equivalent of MS-AF's `request_info` escalation
    node). CopilotKit's `useInterrupt` answers; the gated effect runs only after
    approval — wire it at the consumer."""
    summary = state["messages"][-1].content if state["messages"] else ""
    interrupt({"awaiting_approval": summary})
    return {"messages": []}
{{/has_hitl}}

def build_workflow():
    """Per-request factory: the declared `workflow.chain` AS graph nodes. LangGraph is
    graph-native, so a multi-step chain is just `add_edge` from step to step{{#has_hitl}} + a
    `review` interrupt node for human approval{{/has_hitl}} — the cleanest workflow shape of the
    three runtime targets.{{#cp_pg}} State is checkpointed to Postgres (`PostgresSaver`){{#has_store}} + a
    `PostgresStore` for long-term memory{{/has_store}}; DSNs from the infra refs via env vars.{{/cp_pg}}"""
{{{checkpoint_imports}}}

    graph = StateGraph(State)
{{#workflow_steps}}    graph.add_node({{{name_literal_step}}}, _{{func}}_node)
{{/workflow_steps}}{{#has_hitl}}    graph.add_node("review", _review_node)
{{/has_hitl}}    graph.add_edge(START, {{{first_node_literal}}})
{{#workflow_edges}}    graph.add_edge({{{from_literal}}}, {{{to_literal}}})
{{/workflow_edges}}    graph.add_edge({{{last_node_literal}}}, END)
    return graph.compile(checkpointer={{{checkpointer_expr}}}{{#has_store}}, store={{{store_expr}}}{{/has_store}})
{{/has_workflow}}
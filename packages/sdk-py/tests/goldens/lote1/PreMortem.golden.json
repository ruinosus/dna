{
 "_doc": "FROZEN GOLDEN — captured 2026-06-10 from the live PreMortemKind class (pre-deletion), F3 lote-1. Deep-equaled against the descriptor-synthesized port in test_lote1_descriptor_equivalence.py.",
 "dep_filters": {
  "source_story": "sdlc-story"
 },
 "flags": {
  "flatten_in_context": false,
  "is_overlayable": true,
  "is_prompt_target": false,
  "is_root": false,
  "is_runtime_artifact": false,
  "plane": "record",
  "prompt_target_priority": 0,
  "scope": "global",
  "scope_inheritable": true,
  "volatile_spec_fields": [
   "created_at",
   "updated_at",
   "version"
  ]
 },
 "identity": {
  "alias": "cognitive-pre-mortem",
  "api_version": "github.com/ruinosus/dna/cognitive/v1",
  "ascii_icon": "↩️",
  "display_label": "PreMortems",
  "docs": "A PreMortem rewinds a Story's history and asks what would have happened on the other branch. Generated by a deep-sleep hindsight hook after Stories ship/cancel. Verifiable: would_have_changed predictions are compared against current state at outcome_check_at — same verifier as SynthesisRun.",
  "graph_style": {
   "fill": "#FBBF24",
   "stroke": "#D97706",
   "text_color": "#fff"
  },
  "kind": "PreMortem",
  "origin": "github.com/ruinosus/dna/cognitive"
 },
 "schema": {
  "properties": {
   "alternative": {
    "description": "Prose: 'If instead of <outcome>, the Story had <other path>, then...'. 2-4 sentences.",
    "type": "string"
   },
   "divergence_point": {
    "description": "Decision/event that branched the timeline. Cite a date or trigger event.",
    "type": "string"
   },
   "drafted_at": {
    "format": "date-time",
    "type": "string"
   },
   "evidence_against": {
    "default": [],
    "description": "Doc refs that complicate the counterfactual.",
    "items": {
     "type": "string"
    },
    "type": "array"
   },
   "evidence_for": {
    "default": [],
    "description": "Doc refs supporting the counterfactual.",
    "items": {
     "type": "string"
    },
    "type": "array"
   },
   "generated_by": {
    "type": "string"
   },
   "outcome_check_at": {
    "description": "When to verify (same loop as SynthesisRun).",
    "format": "date-time",
    "type": "string"
   },
   "source_outcome": {
    "description": "What ACTUALLY happened to source_story.",
    "enum": [
     "cancelled",
     "done",
     "dropped",
     "paused"
    ],
    "type": "string"
   },
   "source_story": {
    "description": "Slug of the Story being rewritten (e.g. 's-foo-bar').",
    "type": "string"
   },
   "status": {
    "default": "drafted",
    "enum": [
     "drafted",
     "observing",
     "realized",
     "falsified"
    ],
    "type": "string"
   },
   "strength": {
    "default": "medium",
    "enum": [
     "weak",
     "medium",
     "strong"
    ],
    "type": "string"
   },
   "tags": {
    "default": [],
    "items": {
     "type": "string"
    },
    "type": "array"
   },
   "verifications": {
    "default": [],
    "description": "Verification trace (auto-populated by the verifier).",
    "items": {
     "type": "object"
    },
    "type": "array"
   },
   "would_have_changed": {
    "description": "Predictions same shape as SynthesisRun.would_change. Verifiable via same measure_metrics path.",
    "items": {
     "properties": {
      "by": {
       "format": "date",
       "type": "string"
      },
      "from": {},
      "metric": {
       "type": "string"
      },
      "to": {}
     },
     "required": [
      "metric",
      "from",
      "to"
     ],
     "type": "object"
    },
    "type": "array"
   }
  },
  "required": [
   "source_story",
   "source_outcome",
   "alternative",
   "divergence_point",
   "would_have_changed"
  ],
  "type": "object"
 },
 "storage": {
  "body_as": "text",
  "body_field": "body",
  "container": "pre-mortems",
  "marker": "PRE_MORTEM.md",
  "pattern": "bundle"
 },
 "summary_cases": {
  "full": {
   "out": {
    "alternative": "If instead of done, the Story had been dropped, then…",
    "divergence_point": "2026-06-01 decision",
    "source_outcome": "done",
    "source_story": "s-foo",
    "would_have_changed": [
     {
      "from": 5,
      "metric": "lead_time",
      "to": 9
     }
    ]
   },
   "spec": {
    "alternative": "If instead of done, the Story had been dropped, then…",
    "divergence_point": "2026-06-01 decision",
    "source_outcome": "done",
    "source_story": "s-foo",
    "would_have_changed": [
     {
      "from": 5,
      "metric": "lead_time",
      "to": 9
     }
    ]
   }
  },
  "partial": {
   "out": {},
   "spec": {}
  }
 }
}
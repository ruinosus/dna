     "asc",
     "desc"
    ],
    "type": "string"
   },
   "tags": {
    "items": {
     "type": "string"
    },
    "type": "array"
   },
   "target_kind": {
    "description": "Kind name this view targets (Story, Bug, Spike, ...).",
    "type": "string"
   },
   "title": {
    "description": "Human label (e.g. 'My open Stories', 'This sprint blocked').",
    "type": "string"
   },
   "updated_at": {
    "format": "date-time",
    "type": "string"
   },
   "visibility": {
    "default": "private",
    "enum": [
     "private",
     "team",
     "shared"
    ],
    "type": "string"
   },
   "visible_columns": {
    "description": "Subset of properties shown (table layout). Empty = show all default columns.",
    "items": {
     "type": "string"
    },
    "type": "array"
   }
  },
  "required": [
   "title",
   "target_kind",
   "layout"
  ],
  "type": "object"
 },

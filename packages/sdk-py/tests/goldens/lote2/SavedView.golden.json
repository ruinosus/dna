   },
   "is_default": {
    "default": false,
    "description": "Whether this view loads by default when opening the target Kind list.",
    "type": "boolean"
   },
   "layout": {
    "description": "Visual layout pra render (board=group-by-status, list=flat, ...).",
    "enum": [
     "board",
     "list",
     "tree",
     "table",
     "timeline",
     "calendar",
     "gallery"
    ],
    "type": "string"
   },
   "owner": {
    "description": "Actor name (creator). Determines edit permission.",
    "type": "string"
   },
   "sort_by": {
    "description": "Property to sort by.",
    "type": "string"
   },
   "sort_direction": {
    "default": "asc",
